# ── Base de Datos — Local ──────────────────────────────────────────
# Obtener en: https://console.neon.tech → tu proyecto → Connection Details
DATABASE_URL=postgresql://postgres:postgres@db:5432/erpgrafico
# ── Redis — Local Docker ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/erpgrafico
# ── Storage — Cloudflare R2 ─────────────────────────────────────────────────────
# Obtener en: https://dash.cloudflare.com → R2 → Manage API tokens
USE_S3=True
AWS_ACCESS_KEY_ID=dd93092082323c1d8f79f83f7dcb7100
AWS_SECRET_ACCESS_KEY=b7eb3a738925a3b7bb7ad1179503c5730a5e811865937e7fd6842d6670c189d7
AWS_S3_ENDPOINT_URL=https://ffd21744f00c87b2697a17a3fd66f09c.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto
AWS_S3_ADDRESSING_STYLE=path
AWS_STORAGE_BUCKET_NAME=erpgrafico-media-private
AWS_STORAGE_PUBLIC_BUCKET_NAME=erpgrafico-media-public
AWS_STORAGE_PRIVATE_BUCKET_NAME=erpgrafico-media-private
# URL pública del bucket público (R2 → Bucket → Settings → Public Access → r2.dev subdomain)
AWS_S3_CUSTOM_DOMAIN=pub-a723d7beee0f4252b2707f783af03a80.r2.dev
# ── Django ──────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=genera-uno-con-python-secrets
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.93
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:80,http://127.0.0.1:3000,http://192.168.1.93:3000,http://192.168.1.93
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.93:3000,http://192.168.1.93
# ── Email — Mailpit (local Docker) ──────────────────────────────────────────────
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@erpgrafico.local
# ── Frontend local ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://192.168.1.93/api
# Healthchecks.io — verificación de uptime
#   Free tier: 20 checks. Crear check en: https://healthchecks.io
#   Recomendado: período 10 min, grace 5 min (la tarea Celery pinga cada 5 min).
#   Sin HEALTHCHECK_PING_URL la tarea es no-op.
#
HEALTHCHECK_PING_URL= https://hc-ping.com/cd84ba64-c3aa-4c37-8c62-24f8f45cfe7c 

# Estrategia y setup completo: docs/50-audit/observability/sprint-2-setup.md
#
# Sentry — captura de errores y trazas
#   Free tier: 5k errores/mes y 10k transactions/mes en sentry.io
#   Crear proyecto en: https://sentry.io → New Project → Django (backend) y Next.js (frontend)
#   Sin SENTRY_DSN definido, el SDK no se inicializa y no se envía nada.
#
SENTRY_DSN=https://eed9c9db4e06115dad7f0c3e08fb077b@o4511411706462208.ingest.us.sentry.io/4511411721601024
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.05

# Frontend — DSN público (mismo proyecto que el backend en desarrollo)
NEXT_PUBLIC_SENTRY_DSN=https://eed9c9db4e06115dad7f0c3e08fb077b@o4511411706462208.ingest.us.sentry.io/4511411721601024
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05

# Frontend build — solo necesario en CI para subir sourcemaps a Sentry.
# Sin las tres (SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN) el build no
# llama a withSentryConfig y no requiere la dependencia instalada para correr.
SENTRY_ORG=secuencia-digital
SENTRY_PROJECT=frontend-erp
SENTRY_AUTH_TOKEN=

