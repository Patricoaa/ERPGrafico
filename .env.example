# ================================================================================
# ERPGrafico — Variables de Entorno
# Copia este archivo a .env.dev y completa los valores reales.
# NUNCA commitees .env.dev — está en .gitignore.
# ================================================================================

# ── Base de Datos ────────────────────────────────────────────────────────────────
#
# OPCIÓN A — Cloud (Neon.tech, recomendado para dev con recursos limitados)
#   Obtener en: https://console.neon.tech → tu proyecto → Connection Details
#   DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
#
# OPCIÓN B — Docker local (stack completo)
#   Dejar DATABASE_URL vacío y configurar las variables individuales:
#
DATABASE_URL=

# Solo necesario si NO se usa DATABASE_URL (Opción B)
POSTGRES_DB=erpgrafico
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Redis ────────────────────────────────────────────────────────────────────────
#
# OPCIÓN A — Docker local (recomendado, solo 128 MB)
#   REDIS_URL=redis://localhost:6379
#
# OPCIÓN B — Upstash (cloud gratuito, serverless)
#   Obtener en: https://console.upstash.com → tu base → REST API → Redis URL
#   REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379
#
REDIS_URL=redis://localhost:6379

# ── Storage de Archivos ──────────────────────────────────────────────────────────
#
# OPCIÓN A — Cloudflare R2 (cloud gratuito, 10 GB/mes)
#   Obtener en: https://dash.cloudflare.com → R2 → Manage API tokens
#   USE_S3=True + completar AWS_* vars
#
# OPCIÓN B — Filesystem local (más simple, sin subida de archivos real)
#   USE_S3=False
#   Los archivos se guardan en backend/media/
#
USE_S3=False

# Solo necesario si USE_S3=True
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT_URL=https://TU_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto
AWS_S3_ADDRESSING_STYLE=path
AWS_STORAGE_BUCKET_NAME=erpgrafico-media-private
AWS_STORAGE_PUBLIC_BUCKET_NAME=erpgrafico-media-public
AWS_STORAGE_PRIVATE_BUCKET_NAME=erpgrafico-media-private
# URL pública del bucket público (R2 → Bucket → Settings → Public Access)
AWS_S3_CUSTOM_DOMAIN=

# ── Django ───────────────────────────────────────────────────────────────────────
#
# Generar SECRET_KEY con:
#   python -c "import secrets; print(secrets.token_hex(50))"
#
DJANGO_SECRET_KEY=cambia-esto-en-produccion
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:80,http://127.0.0.1:3000

# ── Email ────────────────────────────────────────────────────────────────────────
#
# OPCIÓN A — Mailpit (trampa local, Docker, UI en localhost:8025)
#   EMAIL_HOST=localhost
#   EMAIL_PORT=1025
#
# OPCIÓN B — Console (imprime en terminal, sin servidor)
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# OPCIÓN C — Resend.com (cloud gratuito, 3000 emails/mes)
#   EMAIL_HOST=smtp.resend.com
#   EMAIL_PORT=587
#   EMAIL_USE_TLS=True
#   EMAIL_HOST_USER=resend
#   EMAIL_HOST_PASSWORD=tu_api_key_de_resend
#
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@erpgrafico.local

# ── Frontend ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
